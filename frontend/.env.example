# Stellar network used by frontend/lib/stellar.ts.
# Accepted values: TESTNET or PUBLIC. Optional; defaults to TESTNET when unset.
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET

# Planned Horizon RPC endpoint for future frontend chain reads.
# Accepted value: full Horizon URL. Optional and currently not consumed by frontend code.
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# Planned Soroban rental contract ID for real rent-payment signing.
# Accepted value: deployed rental contract ID. Optional and currently not consumed by frontend code.
NEXT_PUBLIC_RENTAL_CONTRACT_ID=

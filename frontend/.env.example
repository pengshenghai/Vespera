# Stellar network used by frontend/lib/stellar.ts.
# Accepted values: TESTNET or PUBLIC. Optional; defaults to TESTNET when unset.
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET

# Horizon RPC endpoint for loading account data during rent-payment signing.
# REQUIRED for signRentPayment to work. Set to a valid Soroban RPC URL.
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# Deployed Soroban rental contract ID for real rent-payment signing.
# REQUIRED for signRentPayment to work. Set to your deployed contract ID.
NEXT_PUBLIC_RENTAL_CONTRACT_ID=
